{
  "name": "javascript_input_validation_service",
  "version": "0.1.0",
  "author": {
    "name": "Peter L Blum"
  },
  "description": "Core. JavaScript library to validate user inputs. This lib is completely standalone from DOM, HTML, and Web APIs.",
  "displayName": "JavaScript Input Validation Service",
  "license": "MIT",
  "main": "lib/src/index.js",
  "typings": "lib/src/index.d.ts",
  "scripts": {
    "compile": "tsc",
    "test": "jest",
    "test:github": "jest --ci --reporters='default' --reporters='./.github/scripts/github-actions-reporter'",
    "typedoc": "typedoc --options typedoc.json"
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "node": true,
      "jest": true
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "eslint": "^8.57.0",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typedoc": "^0.25.12",
    "typescript": "^5.4.3",
    "typescript-eslint": "^7.3.1"
  },
  "madge": {
    "tsConfig": "./tsconfig.json"
  },
  "dependencies": {
    "gulp-jest": "^4.0.4"
  }
}
